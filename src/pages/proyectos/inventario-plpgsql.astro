            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', system-ui, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
            line-height: 1.7;
        }

        /* Nav */
        .navbar {
            padding: 2rem;
            max-width: 1000px;
            margin: 0 auto;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.3s ease;
        }

        .back-link:hover {
            color: white;
        }

        /* Background */
        .background-elements {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at top left, #1e1b4b 0%, var(--bg-color) 70%);
        }

        .shape {
            position: absolute;
            border-radius: 50%;
            filter: blur(100px);
            opacity: 0.4;
            animation: float 15s infinite alternate ease-in-out;
        }

        .shape-1 {
            background: #4f46e5;
            width: 40vw;
            height: 40vw;
            top: -10vh;
            right: -10vw;
        }

        .shape-2 {
            background: #0ea5e9;
            width: 30vw;
            height: 30vw;
            bottom: -10vh;
            left: -5vw;
            animation-delay: -5s;
        }

        @keyframes float {
            0% { transform: translate(0, 0); }
            100% { transform: translate(40px, 40px); }
        }

        /* Layout */
        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 0 2rem 5rem;
            display: flex;
            flex-direction: column;
            gap: 4rem;
        }

        /* Header */
        .header {
            text-align: center;
            animation: fadeIn 0.8s ease-out backwards;
        }

        .badge {
            display: inline-block;
            padding: 0.4rem 1rem;
            border-radius: 2rem;
            background: rgba(99, 102, 241, 0.2);
            color: #818cf8;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(99, 102, 241, 0.3);
        }

        .title {
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1.5rem;
            letter-spacing: -0.02em;
        }

        .highlight {
            background: linear-gradient(135deg, #38bdf8 0%, #818cf8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            font-size: 1.15rem;
            color: var(--text-muted);
            max-width: 700px;
            margin: 0 auto;
        }

        strong {
            color: #fff;
            font-weight: 600;
        }

        /* Sections */
        .content-section {
            animation: fadeUp 0.8s ease-out backwards;
            animation-delay: 0.2s;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 2rem;
            color: #fff;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--glass-border);
        }

        .icon-wrap {
            color: #38bdf8;
            display: flex;
        }

        /* Cards and Blocks */
        .card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 1rem;
            padding: 2rem;
            backdrop-filter: blur(12px);
        }

        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .info-block h3 {
            font-size: 1.2rem;
            color: #fff;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .info-block p {
            color: var(--text-muted);
        }

        /* Parts Layout */
        .part-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
            margin-bottom: 3rem;
            align-items: start;
        }

        .part-container.alternate {
            direction: rtl;
        }

        .part-container.alternate > * {
            direction: ltr;
        }

        .part-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 0.5rem;
            background: rgba(56, 189, 248, 0.2);
            color: #7dd3fc;
            font-weight: 600;
            font-size: 0.8rem;
            margin-bottom: 1rem;
        }
        .bg-green { background: rgba(16, 185, 129, 0.2); color: #6ee7b7; }
        .bg-yellow { background: rgba(245, 158, 11, 0.2); color: #fcd34d; }
        .bg-blue { background: rgba(79, 70, 229, 0.2); color: #a5b4fc; }

        .part-explanation h3 {
            font-size: 1.4rem;
            color: #fff;
            margin-bottom: 1rem;
        }

        .part-explanation p {
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        code {
            font-family: 'Fira Code', monospace;
            background: rgba(255, 255, 255, 0.1);
            padding: 0.2rem 0.4rem;
            border-radius: 0.3rem;
            font-size: 0.9em;
            color: #cbd5e1;
        }

        .status-list {
            margin-top: 1.5rem;
            background: rgba(15, 23, 42, 0.4);
            padding: 1rem;
            border-radius: 0.75rem;
            border: 1px solid var(--glass-border);
            font-size: 0.95rem;
            color: var(--text-muted);
        }

        .status-list ul {
            list-style: none;
            margin-top: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 0.5rem;
        }
        .dot.success { background-color: var(--success); box-shadow: 0 0 8px var(--success); }
        .dot.warning { background-color: var(--warning); box-shadow: 0 0 8px var(--warning); }
        .dot.error { background-color: var(--error); box-shadow: 0 0 8px var(--error); }

        /* Code Block Styling */
        .code-block-wrapper {
            background: #0f111a;
            border-radius: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            overflow: hidden;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5);
            position: relative;
        }

        .code-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .dot-group {
            display: flex;
            gap: 6px;
        }

        .mac-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
        }
        .mac-dot.red { background-color: #ff5f56; }
        .mac-dot.yellow { background-color: #ffbd2e; }
        .mac-dot.green { background-color: #27c93f; }

        .lang-label {
            font-size: 0.75rem;
            color: #64748b;
            font-weight: 600;
            letter-spacing: 0.05em;
        }

        .code-block-wrapper pre {
            margin: 0;
            padding: 1.5rem;
            overflow-x: auto;
            color: #e2e8f0;
        }

        .code-block-wrapper code {
            background: transparent;
            padding: 0;
            color: inherit;
            font-size: 0.9rem;
            line-height: 1.5;
            white-space: pre;
        }

        /* Tests Grid */
        .tests-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
        }

        .test-card {
            background: var(--surface);
            border: 1px solid var(--glass-border);
            border-radius: 1rem;
            overflow: hidden;
            transition: transform 0.3s ease;
        }

        .test-card:hover {
            transform: translateY(-5px);
        }

        .test-card.success-test { border-top: 3px solid var(--success); }
        .test-card.error-test { border-top: 3px solid var(--error); }
        .test-card.skip-test { border-top: 3px solid var(--warning); }

        .test-header {
            padding: 1rem 1.25rem;
            font-weight: 600;
            font-size: 1.05rem;
            background: rgba(0, 0, 0, 0.2);
            border-bottom: 1px solid var(--glass-border);
        }

        .test-cmd {
            padding: 1rem 1.25rem;
            font-family: 'Fira Code', monospace;
            font-size: 0.85rem;
            color: #38bdf8;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .test-cmd code { background: none; padding: 0; color: inherit; }

        .test-result {
            padding: 1.25rem;
            font-size: 0.9rem;
            color: var(--text-muted);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: rgba(0,0,0,0.1);
        }

        .test-result strong {
            color: #fff;
        }

        .test-status {
            padding: 1rem 1.25rem;
            font-size: 0.9rem;
            display: flex;
            align-items: flex-start;
            gap: 0.75rem;
            background: rgba(255, 255, 255, 0.02);
            color: #cbd5e1;
            line-height: 1.5;
        }

        .test-status .icon {
            font-size: 1.1rem;
        }

        /* Reflection / Analysis */
        .reflection-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2rem;
        }

        .analysis-card {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 1rem;
            padding: 2rem;
            position: relative;
            overflow: hidden;
        }

        .analysis-card h3 {
            display: flex;
            align-items: center;
            font-size: 1.3rem;
            margin-bottom: 1.5rem;
            color: #fff;
        }

        .inline-mr {
            margin-right: 0.75rem;
        }

        .analysis-card p {
            color: var(--text-muted);
            margin-bottom: 1rem;
        }

        .analysis-card p:last-child {
            margin-bottom: 0;
        }

        .highlight-text {
            padding: 1rem;
            background: rgba(255, 255, 255, 0.05);
            border-left: 3px solid #818cf8;
            border-radius: 0 0.5rem 0.5rem 0;
            margin-top: 1.5rem !important;
            color: #e2e8f0 !important;
            font-style: italic;
        }

        .glow-blue::before {
            content: '';
            position: absolute;
            top: -50px; left: -50px;
            width: 150px; height: 150px;
            background: rgba(56, 189, 248, 0.15);
            filter: blur(50px);
            border-radius: 50%;
            z-index: -1;
        }

        .glow-green::before {
            content: '';
            position: absolute;
            top: -50px; right: -50px;
            width: 150px; height: 150px;
            background: rgba(16, 185, 129, 0.15);
            filter: blur(50px);
            border-radius: 50%;
            z-index: -1;
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Responsiveness */
        @media (max-width: 860px) {
            .part-container, .part-container.alternate {
                grid-template-columns: 1fr;
                direction: ltr;
            }
            .reflection-grid {
                grid-template-columns: 1fr;
            }
        }
        
        @media (max-width: 600px) {
            .container { padding: 0 1.5rem 3rem; }
            .title { font-size: 2.2rem; }
        }
    </style>
</body>
</html>
